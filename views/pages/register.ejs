<%- include('../partials/header') %>

<div class="card" style="max-width: 500px; margin: 2rem auto;">
  <div class="card-header">
    <div class="card-title">Регистрация</div>
  </div>
  <div class="card-body">
    <form>
      <div class="form-group">
        <label for="firstName" class="form-label">Имя</label>
        <input type="text" id="firstName" class="form-input" required placeholder="Иван">
      </div>
      <div class="form-group">
        <label for="lastName" class="form-label">Фамилия</label>
        <input type="text" id="lastName" class="form-input" required placeholder="Петров">
      </div>
      <div class="form-group">
        <label for="email" class="form-label">Электронная почта</label>
        <input type="email" id="email" class="form-input" required placeholder="user@example.com">
      </div>
      <div class="form-group">
        <label for="password" class="form-label">Пароль (минимум 8 символов)</label>
        <input type="password" id="password" class="form-input" required minlength="8" placeholder="Минимум 8 символов">
      </div>
      <button type="submit" class="btn btn-primary">Зарегистрироваться</button>
    </form>
    <p class="mt-3 text-center">
      Уже есть аккаунт? <a href="/login">Войдите здесь</a>
    </p>
  </div>
</div>

<script src="/js/register.js"></script>

<%- include('../partials/footer') %>
