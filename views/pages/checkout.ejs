<%- include('../partials/header') %>

<div class="container" style="max-width: 800px; margin: 2rem auto;">
  <h1 style="margin-bottom: 2rem; color: var(--text-primary);">Оформление заказа</h1>

  <div id="alert-container"></div>

  <!-- Корзина -->
  <div id="cart-summary" style="background: white; padding: 2rem; border-radius: var(--radius-lg); box-shadow: var(--shadow); margin-bottom: 2rem;">
    <h2 style="margin-bottom: 1rem; color: var(--text-primary);">Ваш заказ</h2>
    <div id="cart-items">
      <p style="color: var(--text-secondary);">Загрузка корзины...</p>
    </div>
    <div id="cart-total" style="margin-top: 1.5rem; padding-top: 1rem; border-top: 2px solid var(--border-color); display: none;">
    </div>
  </div>

  <!-- Форма доставки -->
  <form id="checkout-form" style="background: white; padding: 2rem; border-radius: var(--radius-lg); box-shadow: var(--shadow);">
    <h2 style="margin-bottom: 1.5rem; color: var(--text-primary);">Адрес доставки</h2>
    
    <div class="form-group">
      <label for="shippingAddress" class="form-label">Адрес доставки *</label>
      <textarea 
        id="shippingAddress" 
        name="shippingAddress" 
        class="form-input" 
        rows="4" 
        required 
        placeholder="Введите полный адрес доставки включая город, улицу, дом и квартиру"
        style="resize: vertical;"
      ></textarea>
      <small style="color: var(--text-secondary); display: block; margin-top: 0.5rem;">
        Минимум 10 символов
      </small>
    </div>

    <button type="submit" class="btn btn-success btn-lg" style="width: 100%;">
      ✓ Оформить заказ
    </button>
  </form>
</div>

<script src="/js/checkout-page.js"></script>

<%- include('../partials/footer') %>
