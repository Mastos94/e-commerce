<%- include('../partials/header') %>

<div class="card" style="max-width: 500px; margin: 2rem auto;">
  <div class="card-header">
    <div class="card-title">Вход в систему</div>
  </div>
  <div class="card-body">
    <form>
      <div class="form-group">
        <label for="email" class="form-label">Электронная почта</label>
        <input type="email" id="email" class="form-input" required placeholder="user@example.com">
      </div>
      <div class="form-group">
        <label for="password" class="form-label">Пароль</label>
        <input type="password" id="password" class="form-input" required placeholder="Введите пароль">
      </div>
      <button type="submit" class="btn btn-primary">Войти</button>
    </form>
    <p class="mt-3 text-center">
      Нет аккаунта? <a href="/register">Зарегистрируйтесь здесь</a>
    </p>
  </div>
</div>

<script src="/js/login.js"></script>

<%- include('../partials/footer') %>
